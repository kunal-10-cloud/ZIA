# Zia — Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git — it is in .gitignore

# ─── AI Models ────────────────────────────────────────────────────────────────
# Anthropic (required from Day 1)
ANTHROPIC_API_KEY=sk-ant-...

# Model names — don't hardcode these in code, use settings.*
CLAUDE_SONNET_MODEL=claude-sonnet-4-6
CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001

# ─── Database ─────────────────────────────────────────────────────────────────
# Docker Compose sets these automatically in dev.
# For production: Railway provides this URL automatically.
DATABASE_URL=postgresql+asyncpg://zia:zia_dev_password@postgres:5432/zia_db
DATABASE_URL_SYNC=postgresql://zia:zia_dev_password@postgres:5432/zia_db

# ─── Redis ────────────────────────────────────────────────────────────────────
# Docker Compose sets this automatically in dev.
REDIS_URL=redis://redis:6379/0

# ─── Voice — LiveKit ──────────────────────────────────────────────────────────
# Get from: https://livekit.io (free tier for dev)
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=your_livekit_secret
LIVEKIT_WS_URL=wss://your-project.livekit.cloud

# ─── Speech to Text — Deepgram ───────────────────────────────────────────────
# Get from: https://deepgram.com (free tier: 12,000 min/month)
DEEPGRAM_API_KEY=your_deepgram_key

# ─── Text to Speech — ElevenLabs (Phase A-C) ─────────────────────────────────
# Get from: https://elevenlabs.io (free tier: 10K chars/month)
ELEVENLABS_API_KEY=your_elevenlabs_key
# Zia's voice ID — create a custom voice in ElevenLabs dashboard
ELEVENLABS_VOICE_ID=your_voice_id

# ─── Text to Speech — Cartesia (Phase D+, better Hinglish) ───────────────────
# Not needed until Phase D. Leave blank for now.
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=

# ─── WhatsApp — Twilio ───────────────────────────────────────────────────────
# Get from: https://twilio.com (free sandbox for dev)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
# Options: development | staging | production
# Controls: log level, error detail, debug endpoints

# Secret key for JWT auth — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# ─── Eval Pipeline ────────────────────────────────────────────────────────────
# Where eval reports are saved
EVAL_REPORTS_DIR=./eval_reports

# Notify on eval failures (optional — can be a Slack webhook URL)
EVAL_ALERT_WEBHOOK=

# ─── Dev Shortcuts ────────────────────────────────────────────────────────────
# Set to "true" to skip LLM calls in unit tests (uses mock responses)
MOCK_LLM_IN_TESTS=false

# Set to "true" to log every assembled prompt (verbose — dev only)
LOG_ASSEMBLED_PROMPTS=false

# Token count warning threshold — logs warning if prompt exceeds this
TOKEN_BUDGET_WARN=9000
TOKEN_BUDGET_MAX=10700
